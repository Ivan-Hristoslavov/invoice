# ===========================================
# Invoicy — примерни променливи за среда
# ===========================================
# Копирай: cp .env.example .env.local и попълни стойностите.
# За Vercel: Project → Settings → Environment Variables (Production / Preview).

# ---- NextAuth ----
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# ---- Field encryption (НАП и др.) ----
# Генериране: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-string-here

# ---- Google OAuth (по избор) ----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ---- Stripe (сървър) ----
# Ползва се STRIPE_SECRET_KEY_FIXED или STRIPE_SECRET_KEY (виж src/lib/stripe.ts)
STRIPE_SECRET_KEY=sk_test_...
# STRIPE_SECRET_KEY_FIXED=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Price IDs (от Stripe Dashboard → Products → Price ID)
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_YEARLY_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_BUSINESS_MONTHLY_PRICE_ID=price_...
STRIPE_BUSINESS_YEARLY_PRICE_ID=price_...

# По избор: директни линкове към Stripe Checkout / Payment Links
# STRIPE_STARTER_MONTHLY_URL=
# STRIPE_STARTER_YEARLY_URL=
# STRIPE_PRO_MONTHLY_URL=
# STRIPE_PRO_YEARLY_URL=
# STRIPE_BUSINESS_MONTHLY_URL=
# STRIPE_BUSINESS_YEARLY_URL=

# Legacy имена (още се четат в кода за съвместимост)
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_BUISNESS_PRICE_ID=price_...

# ---- SMTP ----
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_SECURITY=TLS
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_ADDRESS=noreply@example.com

# ---- CompanyBook (ЕИК lookup, само сървърно) ----
COMPANYBOOK_API_KEY=
COMPANYBOOK_API_BASE=https://api.companybook.bg/api/companies

# ---- Публичен профил (сайт, имейли, правни данни) ----
NEXT_PUBLIC_APP_NAME=Invoicy
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=invoicy.bg
NEXT_PUBLIC_SUPPORT_EMAIL=support@invoicy.bg
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_SUPPORT_RESPONSE_HOURS=до 4 работни часа
NEXT_PUBLIC_LEGAL_COMPANY_NAME=
NEXT_PUBLIC_LEGAL_COMPANY_ID=
NEXT_PUBLIC_LEGAL_VAT_ID=
NEXT_PUBLIC_LEGAL_ADDRESS=
NEXT_PUBLIC_CALENDLY_DEMO_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_X_URL=
