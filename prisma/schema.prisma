// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  defaultLocale String    @default("en")
  
  // Stripe related fields
  stripeCustomerId String?  @unique
  
  // Invoice preferences
  defaultVatRate Decimal  @default(20.00) @db.Decimal(5, 2)
  startingInvoiceNumber Int?  // Starting invoice number for migration from other apps (e.g., 1 for 0000000001)
  
  accounts      Account[]
  sessions      Session[]
  companies     Company[]
  clients       Client[]
  products      Product[]
  invoices      Invoice[]
  documents     Document[]
  userRoles     UserRole[]
  subscriptions Subscription[]
  creditNotes   CreditNote[]
  debitNotes    DebitNote[]
  auditLogs     AuditLog[]
  passwordResetTokens PasswordResetToken[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// Invoice-related models

model Company {
  id                String    @id @default(cuid())
  name              String
  email             String?
  phone             String?
  address           String?
  city              String?
  state             String?
  zipCode           String?
  country           String?
  vatNumber         String?   // VAT number for EU companies
  taxIdNumber       String?   // Tax ID for other regions
  registrationNumber String?  // Company registration number
  bankName          String?
  bankAccount       String?
  bankSwift         String?
  bankIban          String?
  logo              String?
  stripeAccountId   String?   // Stripe Connect Account ID
  
  // Bulgarian-specific fields
  bulstatNumber     String?   // Bulgarian company identifier (ЕИК/БУЛСТАТ)
  vatRegistered     Boolean   @default(false) // Whether company is VAT registered (Регистрация по ЗДДС)
  vatRegistrationNumber String? // VAT registration number (№ по ЗДДС)
  mol               String?   // MOL - Manager/Representative (Представляващ/МОЛ)
  accountablePerson String?   // Person responsible for the accounting
  napUserName       String?   // Username for the NAP portal
  napPassword       String?   // Encrypted password for NAP portal
  certificateSerialNumber String? // Certificate serial number for e-signing
  certificateThumbprint String?  // Certificate thumbprint
  uicType           String?   @default("BULSTAT") // Valid values: "BULSTAT" or "EGN"
  
  taxComplianceSystem String?  @default("general") // Tax system: "bulgarian", "eu", or "general"
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  userId            String    
  
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
  creditNotes       CreditNote[]
  debitNotes        DebitNote[]
  invoiceSequences  InvoiceSequence[]
  userRoles         UserRole[]
}

model Client {
  id                String    @id @default(cuid())
  name              String
  email             String?
  phone             String?
  address           String?
  city              String?
  state             String?
  zipCode           String?
  country           String?
  vatNumber         String?   // VAT number for EU companies
  taxIdNumber       String?   // Tax ID for other regions
  
  // Bulgarian-specific fields
  bulstatNumber     String?   // Bulgarian company identifier (ЕИК/БУЛСТАТ)
  vatRegistered     Boolean   @default(false) // Whether client is VAT registered
  vatRegistrationNumber String? // VAT registration number (№ по ЗДДС)
  mol               String?   // MOL - Manager/Representative
  uicType           String?   @default("BULSTAT") // Valid values: "BULSTAT" or "EGN"
  
  taxComplianceSystem String?  @default("general") // Tax system: "bulgarian", "eu", or "general"
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  userId            String
  locale            String    @default("en") // Client preferred locale
  
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
  creditNotes       CreditNote[]
  debitNotes        DebitNote[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  unit        String   @default("piece")
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]
  
  // Product translations
  translations ProductTranslation[]
}

model ProductTranslation {
  id          String @id @default(cuid())
  productId   String
  locale      String
  name        String
  description String?
  unit        String?
  
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([productId, locale])
}

model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String
  clientId        String
  companyId       String
  userId          String
  issueDate       DateTime
  dueDate         DateTime
  status          InvoiceStatus @default(DRAFT)
  subtotal        Decimal  @db.Decimal(10, 2)
  taxAmount       Decimal  @db.Decimal(10, 2)
  discount        Decimal? @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)
  notes           String?
  termsAndConditions String?
  currency        String   @default("EUR")
  locale          String   @default("en") // Invoice language
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Bulgarian tax authority (НАП) specific fields
  bulstatNumber   String?  // Bulgarian BULSTAT/EIK
  isOriginal      Boolean  @default(true) // Whether this is the original or a copy
  uniqueNapId     String?  // Unique identifier for НАП
  placeOfIssue    String?  // Required place where invoice was issued
  paymentMethod   String?  // Начин на плащане (информативно поле): банков превод, по договор, и т.н.
  supplyDate      DateTime? // Date of supply/service delivery (дата на данъчно събитие)
  isEInvoice      Boolean  @default(false) // Whether this is an electronic invoice
  napStatus       String?  // Status of the invoice in the НАП system
  
  // Immutable: invoices cannot be edited after creation, only cancelled → credit note
  cancelledAt     DateTime? // When invoice was cancelled
  cancelledBy     String?   // User ID who cancelled
  creditNoteId    String?   @unique // Reference to credit note if cancelled
  invoiceSequenceId String? @unique // Reference to the sequence used for numbering
  
  client          Client   @relation(fields: [clientId], references: [id])
  company         Company  @relation(fields: [companyId], references: [id])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           InvoiceItem[]
  documents       Document[]
  sequence        InvoiceSequence? @relation(fields: [invoiceSequenceId], references: [id]) // Sequence used for numbering
  creditNote      CreditNote? // Credit note created from this invoice
  debitNotes      DebitNote[] // Debit notes related to this invoice
  auditLogs       AuditLog[]
  
  @@unique([invoiceNumber, userId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  taxAmount   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
}

// InvoiceSequence: Manages sequential numbering per company/year
model InvoiceSequence {
  id          String   @id @default(cuid())
  companyId   String
  year        Int      // Calendar year (e.g., 2026)
  sequence    Int      @default(1) // Current sequence number
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice     Invoice? @relation // The invoice using this sequence
  
  @@unique([companyId, year])
}

// CreditNote: Created when an invoice is cancelled or manually
model CreditNote {
  id              String   @id @default(cuid())
  creditNoteNumber String   @unique
  invoiceId       String?  @unique // Optional reference to cancelled invoice (can be created manually)
  companyId       String
  clientId        String
  userId           String
  issueDate        DateTime
  reason           String?  // Reason for credit note
  subtotal         Decimal  @db.Decimal(10, 2)
  taxAmount        Decimal  @db.Decimal(10, 2)
  total            Decimal  @db.Decimal(10, 2)
  currency         String   @default("EUR")
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  invoice          Invoice? @relation(fields: [invoiceId], references: [id])
  company          Company  @relation(fields: [companyId], references: [id])
  client           Client   @relation(fields: [clientId], references: [id])
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items            CreditNoteItem[]
  
  @@unique([creditNoteNumber, companyId])
}

model CreditNoteItem {
  id            String   @id @default(cuid())
  creditNoteId  String
  description   String
  quantity      Decimal  @db.Decimal(10, 2)
  unitPrice     Decimal  @db.Decimal(10, 2)
  taxRate       Decimal  @default(0) @db.Decimal(5, 2)
  subtotal      Decimal  @db.Decimal(10, 2)
  taxAmount     Decimal  @db.Decimal(10, 2)
  total         Decimal  @db.Decimal(10, 2)
  
  creditNote    CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
}

// DebitNote: Created when replacing a product but customer needs to pay more
model DebitNote {
  id              String   @id @default(cuid())
  debitNoteNumber String   @unique
  invoiceId       String?  // Optional reference to related invoice
  companyId       String
  clientId        String
  userId           String
  issueDate        DateTime
  reason           String?  // Reason for debit note (e.g., product replacement with additional payment)
  subtotal         Decimal  @db.Decimal(10, 2)
  taxAmount        Decimal  @db.Decimal(10, 2)
  total            Decimal  @db.Decimal(10, 2)
  currency         String   @default("EUR")
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  invoice          Invoice?  @relation(fields: [invoiceId], references: [id])
  company          Company  @relation(fields: [companyId], references: [id])
  client           Client   @relation(fields: [clientId], references: [id])
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items            DebitNoteItem[]
  
  @@unique([debitNoteNumber, companyId])
}

model DebitNoteItem {
  id            String   @id @default(cuid())
  debitNoteId  String
  description   String
  quantity      Decimal  @db.Decimal(10, 2)
  unitPrice     Decimal  @db.Decimal(10, 2)
  taxRate       Decimal  @default(0) @db.Decimal(5, 2)
  subtotal      Decimal  @db.Decimal(10, 2)
  taxAmount     Decimal  @db.Decimal(10, 2)
  total         Decimal  @db.Decimal(10, 2)
  
  debitNote    DebitNote @relation(fields: [debitNoteId], references: [id], onDelete: Cascade)
}

// AuditLog: Tracks all changes to invoices and system events
model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  invoiceId   String?
  action      String   // CREATE, UPDATE, CANCEL, SEND, EXPORT, etc.
  entityType  String   // INVOICE, CREDIT_NOTE, CLIENT, COMPANY, etc.
  entityId    String?
  changes     String?  @db.Text // JSON string of changes
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
}

enum InvoiceStatus {
  DRAFT      // Draft invoice, can be edited
  ISSUED     // Invoice issued (immutable, cannot be edited)
  VOIDED     // Draft invoice voided (marked as cancelled before issuing, kept in database)
  CANCELLED  // Issued invoice cancelled, credit note created
}

// PaymentMethod enum removed - payment method is now just a text field in Invoice
// Allowed values: "Банков превод", "По договор", etc. (informative only, no logic)

model Document {
  id        String   @id @default(cuid())
  name      String
  size      Int
  type      String
  url       String
  invoiceId String
  userId    String
  createdAt DateTime @default(now())
  
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// User roles and permissions models

enum Role {
  ADMIN     // System admin with full access
  OWNER     // Business owner with full access to their companies
  MANAGER   // Company manager with access to most features
  ACCOUNTANT // Can manage invoices and financials
  VIEWER    // Read-only access
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      Role     @default(VIEWER)
  companyId String?  // If null, role applies across the system
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@unique([userId, companyId])
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
}

// Subscription models
model Subscription {
  id                   String            @id @default(cuid())
  userId               String
  stripeSubscriptionId String            @unique
  status               SubscriptionStatus
  plan                 SubscriptionPlan
  priceId              String
  quantity             Int               @default(1)
  cancelAtPeriodEnd    Boolean           @default(false)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  
  // Payment history for this subscription
  paymentHistory       SubscriptionPayment[]
  history              SubscriptionHistory[]
  
  // Relation to User
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SubscriptionPayment {
  id                   String            @id @default(cuid())
  subscriptionId       String
  stripeInvoiceId      String            @unique
  amount               Decimal           @db.Decimal(10, 2)
  currency             String            @default("USD")
  status               PaymentStatus
  paymentMethod        String?
  paymentIntentId      String?
  createdAt            DateTime          @default(now())
  
  // Relation to Subscription
  subscription         Subscription      @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model SubscriptionHistory {
  id                   String            @id @default(cuid())
  subscriptionId       String
  status               SubscriptionStatus
  event                String
  createdAt            DateTime          @default(now())
  
  // Relation to Subscription
  subscription         Subscription      @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  UNPAID
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  PAUSED
}

enum SubscriptionPlan {
  FREE      // Free plan: 3 invoices/month, 1 company, 5 clients, 10 products, no logo, no export
  STARTER   // Starter plan: 15 invoices/month, 1 company, 25 clients, 50 products, CSV export
  PRO       // Pro plan: unlimited invoices, 3 companies, 100 clients, 200 products, logo, PDF+CSV, email
  BUSINESS  // Business plan: unlimited everything, 10 companies, logo, export, email, 5 users, API
}

enum PaymentStatus {
  PAID
  UNPAID
  FAILED
  PENDING
  REFUNDED
  VOID
}

// Webhook Event Logging
model WebhookEventLog {
  id          String   @id @default(cuid())
  eventType   String
  eventId     String
  status      String   // SUCCESS or FAILED
  payload     String   @db.Text // JSON payload
  processedAt DateTime @default(now())
  
  @@index([eventType, status])
  @@index([eventId])
}
