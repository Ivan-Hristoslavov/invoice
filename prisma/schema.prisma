// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  defaultLocale String    @default("en")
  
  // Stripe related fields
  stripeCustomerId String?  @unique
  
  // Invoice preferences
  defaultVatRate Decimal  @default(20.00) @db.Decimal(5, 2)
  
  accounts      Account[]
  sessions      Session[]
  companies     Company[]
  clients       Client[]
  products      Product[]
  invoices      Invoice[]
  documents     Document[]
  userRoles     UserRole[]
  subscriptions Subscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Invoice-related models

model Company {
  id                String    @id @default(cuid())
  name              String
  email             String?
  phone             String?
  address           String?
  city              String?
  state             String?
  zipCode           String?
  country           String?
  vatNumber         String?   // VAT number for EU companies
  taxIdNumber       String?   // Tax ID for other regions
  registrationNumber String?  // Company registration number
  bankName          String?
  bankAccount       String?
  bankSwift         String?
  bankIban          String?
  logo              String?
  stripeAccountId   String?   // Stripe Connect Account ID
  
  // Bulgarian-specific fields
  bulstatNumber     String?   // Bulgarian company identifier (ЕИК/БУЛСТАТ)
  vatRegistered     Boolean   @default(false) // Whether company is VAT registered (Регистрация по ЗДДС)
  vatRegistrationNumber String? // VAT registration number (№ по ЗДДС)
  mол               String?   // MOL - Manager/Representative (Представляващ/МОЛ)
  accountablePerson String?   // Person responsible for the accounting
  napUserName       String?   // Username for the NAP portal
  napPassword       String?   // Encrypted password for NAP portal
  certificateSerialNumber String? // Certificate serial number for e-signing
  certificateThumbprint String?  // Certificate thumbprint
  uicType           String?   @default("BULSTAT") // Valid values: "BULSTAT" or "EGN"
  
  taxComplianceSystem String?  @default("general") // Tax system: "bulgarian", "eu", or "general"
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  userId            String    
  
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
  userRoles         UserRole[]
}

model Client {
  id                String    @id @default(cuid())
  name              String
  email             String?
  phone             String?
  address           String?
  city              String?
  state             String?
  zipCode           String?
  country           String?
  vatNumber         String?   // VAT number for EU companies
  taxIdNumber       String?   // Tax ID for other regions
  
  // Bulgarian-specific fields
  bulstatNumber     String?   // Bulgarian company identifier (ЕИК/БУЛСТАТ)
  vatRegistered     Boolean   @default(false) // Whether client is VAT registered
  vatRegistrationNumber String? // VAT registration number (№ по ЗДДС)
  mол               String?   // MOL - Manager/Representative
  uicType           String?   @default("BULSTAT") // Valid values: "BULSTAT" or "EGN"
  
  taxComplianceSystem String?  @default("general") // Tax system: "bulgarian", "eu", or "general"
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  userId            String
  locale            String    @default("en") // Client preferred locale
  
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  unit        String   @default("piece")
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]
  
  // Product translations
  translations ProductTranslation[]
}

model ProductTranslation {
  id          String @id @default(cuid())
  productId   String
  locale      String
  name        String
  description String?
  unit        String?
  
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([productId, locale])
}

model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String
  clientId        String
  companyId       String
  userId          String
  issueDate       DateTime
  dueDate         DateTime
  status          InvoiceStatus @default(DRAFT)
  paidAt          DateTime? // When the invoice was paid
  subtotal        Decimal  @db.Decimal(10, 2)
  taxAmount       Decimal  @db.Decimal(10, 2)
  discount        Decimal? @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)
  notes           String?
  termsAndConditions String?
  currency        String   @default("USD")
  locale          String   @default("en") // Invoice language
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Bulgarian tax authority (НАП) specific fields
  bulstatNumber   String?  // Bulgarian BULSTAT/EIK
  isOriginal      Boolean  @default(true) // Whether this is the original or a copy
  uniqueNapId     String?  // Unique identifier for НАП
  placeOfIssue    String?  // Required place where invoice was issued
  paymentMethod   String?  // For tracking payment method as per Bulgarian requirements
  supplyDate      DateTime? // Date of supply/service delivery (дата на данъчно събитие)
  isEInvoice      Boolean  @default(false) // Whether this is an electronic invoice
  napStatus       String?  // Status of the invoice in the НАП system
  
  client          Client   @relation(fields: [clientId], references: [id])
  company         Company  @relation(fields: [companyId], references: [id])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           InvoiceItem[]
  payments        Payment[]
  documents       Document[]
  
  @@unique([invoiceNumber, companyId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  taxAmount   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
}

model Payment {
  id          String       @id @default(cuid())
  invoiceId   String
  amount      Decimal      @db.Decimal(10, 2)
  paymentDate DateTime
  paymentMethod PaymentMethod
  transactionId String?    // Stripe transaction ID or reference
  reference   String?
  notes       String?
  refundedPaymentId String? // Reference to the original payment if this is a refund
  status      String?      // Status of the payment: PAID, FAILED, REFUNDED, etc.
  createdAt   DateTime     @default(now())
  
  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CREDIT_CARD
  APPLE_PAY
  GOOGLE_PAY
  WIRE_TRANSFER
  OTHER
}

model Document {
  id        String   @id @default(cuid())
  name      String
  size      Int
  type      String
  url       String
  invoiceId String
  userId    String
  createdAt DateTime @default(now())
  
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// User roles and permissions models

enum Role {
  ADMIN     // System admin with full access
  OWNER     // Business owner with full access to their companies
  MANAGER   // Company manager with access to most features
  ACCOUNTANT // Can manage invoices and financials
  VIEWER    // Read-only access
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      Role     @default(VIEWER)
  companyId String?  // If null, role applies across the system
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@unique([userId, companyId])
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
}

// Subscription models
model Subscription {
  id                   String            @id @default(cuid())
  userId               String
  stripeSubscriptionId String            @unique
  status               SubscriptionStatus
  plan                 SubscriptionPlan
  priceId              String
  quantity             Int               @default(1)
  cancelAtPeriodEnd    Boolean           @default(false)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  
  // Payment history for this subscription
  paymentHistory       SubscriptionPayment[]
  history              SubscriptionHistory[]
  
  // Relation to User
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SubscriptionPayment {
  id                   String            @id @default(cuid())
  subscriptionId       String
  stripeInvoiceId      String            @unique
  amount               Decimal           @db.Decimal(10, 2)
  currency             String            @default("USD")
  status               PaymentStatus
  paymentMethod        String?
  paymentIntentId      String?
  createdAt            DateTime          @default(now())
  
  // Relation to Subscription
  subscription         Subscription      @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model SubscriptionHistory {
  id                   String            @id @default(cuid())
  subscriptionId       String
  status               SubscriptionStatus
  event                String
  createdAt            DateTime          @default(now())
  
  // Relation to Subscription
  subscription         Subscription      @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  UNPAID
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  PAUSED
}

enum SubscriptionPlan {
  BASIC
  PRO
  VIP
}

enum PaymentStatus {
  PAID
  UNPAID
  FAILED
  PENDING
  REFUNDED
  VOID
}

// Webhook Event Logging
model WebhookEventLog {
  id          String   @id @default(cuid())
  eventType   String
  eventId     String
  status      String   // SUCCESS or FAILED
  payload     String   @db.Text // JSON payload
  processedAt DateTime @default(now())
  
  @@index([eventType, status])
  @@index([eventId])
}
