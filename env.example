# Application settings
PORT=3000
NODE_ENV=development


DB_CLIENT=postgres
DB_HOST=localhost
DB_SCHEMA=invoice
DB_PORT=5432
DB_USERNAME=root
DB_PASSWORD=mysecretpassword
DB=postgres

# Prisma database URL
DATABASE_URL="postgresql://root:mysecretpassword@localhost:5432/postgres?schema=invoice"

# Prisma database URL

# Authentication
NEXTAUTH_SECRET="your-secret-key-for-jwt"


# Stripe URLs for checkout
