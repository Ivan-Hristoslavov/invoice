# Application settings
PORT=3000
NODE_ENV=development

# Database
DB_CLIENT=postgres
DB_HOST=localhost
DB_SCHEMA=invoice
DB_PORT=5432
DB_USERNAME=root
DB_PASSWORD=mysecretpassword
DB=postgres

# Prisma database URL (required by Prisma)
# For local development with Docker:
DATABASE_URL="postgresql://root:mysecretpassword@localhost:5432/postgres?schema=invoice"
# For Supabase, use the connection string from your Supabase project settings:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.ydkkciowyhgawxvrllse.supabase.co:5432/postgres?schema=invoice"

# Authentication
NEXTAUTH_SECRET="your-secret-key-for-jwt"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# For production, use: NEXT_PUBLIC_APP_URL="https://facturapro.bg"

# Google OAuth (optional - for Google sign-in)
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe Configuration
# Stripe Secret Key (use STRIPE_SECRET_KEY_FIXED for production)
STRIPE_SECRET_KEY_FIXED=sk_test_your_secret_key_here
# Alternative: STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe Publishable Key (for client-side Stripe.js)
STRIPE_PUBLISH_KEY=pk_test_your_publishable_key_here

# Stripe Webhook Secret (get this after setting up a webhook in your Stripe dashboard)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Product/Price IDs
# Note: These should be Price IDs (starting with price_) not Product IDs (starting with prod_)
# If you have Product IDs, you need to create Price IDs for those products in Stripe dashboard
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_BUISNESS_PRICE_ID=price_your_business_price_id

# Stripe Prices (can be managed from Vercel)
# These are the actual prices in EUR that users will pay
STRIPE_PRO_PRICE=13
STRIPE_BUISNESS_PRICE=28

# Optional: Yearly Price IDs (if you have separate yearly prices)
# STRIPE_PRO_YEARLY_PRICE_ID=price_your_pro_yearly_price_id
# STRIPE_BUISNESS_YEARLY_PRICE_ID=price_your_business_yearly_price_id

# Optional: Stripe Checkout URLs (Payment Links)
# STRIPE_PRO_MONTHLY_URL=https://buy.stripe.com/your_pro_monthly_link
# STRIPE_PRO_YEARLY_URL=https://buy.stripe.com/your_pro_yearly_link
# STRIPE_BUSINESS_MONTHLY_URL=https://buy.stripe.com/your_business_monthly_link
# STRIPE_BUSINESS_YEARLY_URL=https://buy.stripe.com/your_business_yearly_link

# SMTP Email Configuration
# SMTP Server (Gmail: smtp.gmail.com, alternatives: Sendgrid, Mailgun, SMTP2GO, sendinblue, JangoSMTP, GMass)
SMTP_SERVER=smtp.gmail.com
# SMTP Port (common ports: 25, 2525, 465, 587)
SMTP_PORT=465
# SMTP Security (SSL or TLS)
SMTP_SECURITY=SSL
# SMTP Username (usually your email address)
SMTP_USERNAME=your_smtp_username
# SMTP Password (use an app-specific password for Gmail)
SMTP_PASSWORD=your_smtp_password_here
# From email address (sender email)
SMTP_FROM_ADDRESS=your_from_email@example.com
# To email address (for testing purposes)
SMTP_TO_ADDRESS=your_test_recipient@example.com
